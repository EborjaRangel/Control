# URL del backend (proxy de Next.js hacia el API)
# Desarrollo: http://localhost:4000
# Vercel: https://tu-proyecto.up.railway.app (sin barra final)
API_PROXY_URL="http://localhost:4000"

# URL pública de la app (QR de asistencia)
# Vercel: https://tu-proyecto.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mapbox (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.tu_token_publico_de_mapbox"
# Opcional: estilo del mapa (light-v11, streets-v12, outdoors-v12, etc.)
NEXT_PUBLIC_MAPBOX_STYLE="mapbox://styles/mapbox/light-v11"
