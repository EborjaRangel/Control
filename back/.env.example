# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/control"

# Puerto del API
PORT=4000

# Origen permitido del frontend (CORS). Varios orígenes separados por coma.
# Producción: https://tu-proyecto.vercel.app
FRONTEND_URL="http://localhost:3000"

# URL pública de la app (enlaces en QR de asistencia y convocatorias)
PUBLIC_APP_URL="http://localhost:3000"

# Autenticación JWT (cambiar en producción)
JWT_SECRET="genera-un-secreto-largo-y-aleatorio"

# Usuario administrador inicial (npm run db:seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# --- Convocatoria: envíos reales (correo, SMS y WhatsApp) ---
# Obligatorias para enviar convocatorias. Sin simulación.

# Correo SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-correo@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion"
SMTP_FROM="Control Coyoacán <tu-correo@gmail.com>"

# Twilio — SMS y WhatsApp
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="tu-auth-token"
TWILIO_SMS_FROM="+521234567890"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
